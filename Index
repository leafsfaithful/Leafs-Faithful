<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Leafs Faithful — Toronto's Home for Leafs Coverage</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --blue: #003E7E;
    --blue-light: #1B5EA6;
    --blue-dark: #00254D;
    --white: #FFFFFF;
    --off-white: #F4F7FB;
    --gray: #8A9BB0;
    --gray-light: #E8EEF5;
    --accent: #00AEEF;
    --ice: #D6E8F7;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Barlow', sans-serif;
    background: var(--off-white);
    color: var(--blue-dark);
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    background: var(--blue-dark);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 3px solid var(--accent);
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 64px;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }
  .nav-logo img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid var(--accent);
  }
  .nav-logo span {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--white);
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .nav-links {
    display: flex;
    gap: 4px;
    list-style: none;
  }
  .nav-links a {
    color: var(--gray);
    text-decoration: none;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 8px 14px;
    border-radius: 4px;
    transition: all 0.2s;
  }
  .nav-links a:hover, .nav-links a.active {
    color: var(--white);
    background: rgba(255,255,255,0.08);
  }
  .nav-x-btn {
    background: var(--accent);
    color: var(--blue-dark) !important;
    font-weight: 700 !important;
    padding: 7px 16px !important;
    border-radius: 20px !important;
  }
  .nav-x-btn:hover {
    background: var(--white) !important;
    color: var(--blue-dark) !important;
  }

  /* HERO */
  .hero {
    background: linear-gradient(135deg, var(--blue-dark) 0%, var(--blue) 60%, var(--blue-light) 100%);
    position: relative;
    overflow: hidden;
    padding: 80px 24px 90px;
    text-align: center;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 20% 50%, rgba(0,174,239,0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.05) 0%, transparent 50%);
  }
  .hero-rink-lines {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: 
      repeating-linear-gradient(90deg, var(--white) 0px, var(--white) 1px, transparent 1px, transparent 60px),
      repeating-linear-gradient(0deg, var(--white) 0px, var(--white) 1px, transparent 1px, transparent 60px);
  }
  .hero-content {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
  }
  .hero-logo {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    border: 4px solid var(--accent);
    box-shadow: 0 0 40px rgba(0,174,239,0.4), 0 8px 32px rgba(0,0,0,0.4);
    margin: 0 auto 24px;
    display: block;
    animation: heroFloat 4s ease-in-out infinite;
  }
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }
  .hero h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(48px, 8vw, 80px);
    font-weight: 900;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 3px;
    line-height: 1;
    margin-bottom: 8px;
  }
  .hero h1 span { color: var(--accent); }
  .hero-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--ice);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .hero-desc {
    font-size: 16px;
    color: rgba(255,255,255,0.7);
    max-width: 480px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }
  .hero-btns {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--blue-dark);
    padding: 13px 28px;
    border-radius: 4px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
  }
  .btn-primary:hover { background: var(--white); transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.3); }
  .btn-secondary {
    background: transparent;
    color: var(--white);
    padding: 13px 28px;
    border-radius: 4px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid rgba(255,255,255,0.3);
    transition: all 0.2s;
    cursor: pointer;
  }
  .btn-secondary:hover { border-color: var(--white); background: rgba(255,255,255,0.08); }

  /* TICKER */
  .ticker {
    background: var(--blue);
    padding: 10px 0;
    overflow: hidden;
    border-bottom: 2px solid var(--accent);
  }
  .ticker-inner {
    display: flex;
    animation: ticker 25s linear infinite;
    white-space: nowrap;
  }
  .ticker-item {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 0 40px;
  }
  .ticker-item span { color: var(--accent); margin-right: 10px; }
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* MAIN LAYOUT */
  .main-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 24px;
  }

  /* SECTION HEADERS */
  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }
  .section-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--blue-dark);
  }
  .section-line {
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent);
  }
  .section-badge {
    background: var(--blue);
    color: var(--white);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 20px;
  }

  /* TWO COL LAYOUT */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 32px;
    align-items: start;
  }

  /* FEATURED ARTICLE */
  .featured-card {
    background: var(--white);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 16px rgba(0,62,126,0.08);
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer;
    margin-bottom: 24px;
  }
  .featured-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,62,126,0.15); }
  .featured-img {
    width: 100%;
    height: 240px;
    background: linear-gradient(135deg, var(--blue-dark), var(--blue-light));
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .featured-img::after {
    content: '🏒';
    font-size: 80px;
    opacity: 0.3;
  }
  .featured-tag {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--accent);
    color: var(--blue-dark);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 2px;
  }
  .featured-body { padding: 24px; }
  .featured-body h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 26px;
    font-weight: 800;
    color: var(--blue-dark);
    line-height: 1.2;
    margin-bottom: 10px;
  }
  .featured-body p { font-size: 15px; color: #5a6a7e; line-height: 1.6; margin-bottom: 16px; }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    color: var(--gray);
    font-weight: 500;
  }
  .article-meta span { display: flex; align-items: center; gap: 4px; }

  /* ARTICLE GRID */
  .article-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .article-card {
    background: var(--white);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,62,126,0.07);
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer;
  }
  .article-card:hover { transform: translateY(-3px); box-shadow: 0 6px 24px rgba(0,62,126,0.13); }
  .article-card-img {
    height: 120px;
    background: linear-gradient(135deg, var(--blue-dark), var(--blue));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36px;
  }
  .article-card-body { padding: 16px; }
  .article-card-body h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--blue-dark);
    line-height: 1.25;
    margin-bottom: 8px;
  }
  .article-card-body p { font-size: 13px; color: var(--gray); line-height: 1.5; }
  .article-tag {
    display: inline-block;
    background: var(--ice);
    color: var(--blue);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    margin-bottom: 8px;
  }

  /* SIDEBAR */
  .sidebar { display: flex; flex-direction: column; gap: 24px; }

  /* CONTEST CARD */
  .contest-card {
    background: linear-gradient(135deg, var(--blue-dark) 0%, var(--blue) 100%);
    border-radius: 8px;
    padding: 24px;
    color: var(--white);
    position: relative;
    overflow: hidden;
  }
  .contest-card::before {
    content: '🏆';
    position: absolute;
    right: -10px;
    top: -10px;
    font-size: 80px;
    opacity: 0.1;
  }
  .contest-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .contest-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
    line-height: 1.2;
  }
  .contest-prize {
    background: var(--accent);
    color: var(--blue-dark);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px;
    font-weight: 900;
    text-align: center;
    padding: 12px;
    border-radius: 6px;
    margin: 16px 0;
    letter-spacing: 1px;
  }
  .contest-steps { list-style: none; margin-bottom: 16px; }
  .contest-steps li {
    font-size: 14px;
    color: rgba(255,255,255,0.85);
    padding: 5px 0;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .contest-steps li:last-child { border: none; }
  .contest-steps li span { color: var(--accent); font-weight: 700; }
  .btn-contest {
    display: block;
    background: var(--white);
    color: var(--blue-dark);
    text-align: center;
    padding: 12px;
    border-radius: 4px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 15px;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
    width: 100%;
  }
  .btn-contest:hover { background: var(--accent); }

  /* STANDINGS WIDGET */
  .widget-card {
    background: var(--white);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,62,126,0.07);
  }
  .widget-header {
    background: var(--blue-dark);
    padding: 14px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .widget-header h4 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .widget-header span { font-size: 12px; color: var(--accent); font-weight: 600; }
  .widget-body { padding: 16px; }
  .standings-row {
    display: flex;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--gray-light);
    font-size: 14px;
  }
  .standings-row:last-child { border: none; }
  .standings-pos { width: 24px; font-weight: 700; color: var(--gray); font-size: 13px; }
  .standings-team { flex: 1; font-weight: 600; color: var(--blue-dark); }
  .standings-team.leafs { color: var(--blue); font-weight: 700; }
  .standings-pts {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 16px;
    color: var(--blue-dark);
    width: 32px;
    text-align: right;
  }
  .standings-record { color: var(--gray); font-size: 12px; width: 60px; text-align: right; }

  /* NEWSLETTER WIDGET */
  .newsletter-card {
    background: var(--white);
    border-radius: 8px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0,62,126,0.07);
    text-align: center;
    border-top: 4px solid var(--accent);
  }
  .newsletter-card h4 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 800;
    color: var(--blue-dark);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .newsletter-card p { font-size: 13px; color: var(--gray); margin-bottom: 16px; line-height: 1.5; }
  .newsletter-input {
    width: 100%;
    padding: 10px 14px;
    border: 2px solid var(--gray-light);
    border-radius: 4px;
    font-size: 14px;
    font-family: 'Barlow', sans-serif;
    outline: none;
    margin-bottom: 10px;
    transition: border-color 0.2s;
  }
  .newsletter-input:focus { border-color: var(--accent); }

  /* DISCUSSION SECTION */
  .discussion-section { margin-top: 48px; }
  .discussion-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }
  .thread-card {
    background: var(--white);
    border-radius: 8px;
    padding: 18px;
    box-shadow: 0 2px 12px rgba(0,62,126,0.07);
    cursor: pointer;
    transition: all 0.2s;
    border-left: 4px solid transparent;
  }
  .thread-card:hover { border-left-color: var(--accent); transform: translateY(-2px); }
  .thread-tag {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 6px;
  }
  .thread-card h4 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--blue-dark);
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .thread-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: var(--gray);
  }
  .thread-replies {
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 600;
    color: var(--blue);
  }

  /* POST COMMENT */
  .post-comment-box {
    background: var(--white);
    border-radius: 8px;
    padding: 24px;
    box-shadow: 0 2px 12px rgba(0,62,126,0.07);
  }
  .post-comment-box h4 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 800;
    color: var(--blue-dark);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
  }
  .comment-form { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .comment-form input, .comment-form textarea {
    padding: 10px 14px;
    border: 2px solid var(--gray-light);
    border-radius: 4px;
    font-size: 14px;
    font-family: 'Barlow', sans-serif;
    outline: none;
    transition: border-color 0.2s;
    resize: none;
  }
  .comment-form input:focus, .comment-form textarea:focus { border-color: var(--accent); }
  .comment-form textarea { grid-column: 1 / -1; height: 100px; }
  .comment-form .btn-primary { grid-column: 1 / -1; }

  /* EXISTING COMMENTS */
  .comments-list { margin-top: 24px; }
  .comment {
    display: flex;
    gap: 12px;
    padding: 16px 0;
    border-bottom: 1px solid var(--gray-light);
  }
  .comment:last-child { border: none; }
  .comment-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--blue);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    color: var(--white);
    font-size: 16px;
    flex-shrink: 0;
  }
  .comment-content { flex: 1; }
  .comment-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }
  .comment-name {
    font-weight: 700;
    font-size: 14px;
    color: var(--blue-dark);
  }
  .comment-time { font-size: 12px; color: var(--gray); }
  .comment-text { font-size: 14px; color: #4a5a6e; line-height: 1.6; }
  .comment-like {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: var(--gray);
    margin-top: 8px;
    cursor: pointer;
    width: fit-content;
    transition: color 0.2s;
  }
  .comment-like:hover { color: var(--blue); }

  /* ABOUT SECTION */
  .about-section {
    background: linear-gradient(135deg, var(--blue-dark), var(--blue));
    border-radius: 8px;
    padding: 48px;
    margin-top: 48px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 40px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .about-section::before {
    content: '';
    position: absolute;
    right: -60px;
    top: -60px;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    border: 40px solid rgba(255,255,255,0.04);
  }
  .about-section h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 36px;
    font-weight: 900;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }
  .about-section h2 span { color: var(--accent); }
  .about-section p { font-size: 16px; color: rgba(255,255,255,0.75); line-height: 1.7; max-width: 500px; }
  .about-logo {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 4px solid var(--accent);
    box-shadow: 0 0 40px rgba(0,174,239,0.3);
  }

  /* FOOTER */
  footer {
    background: var(--blue-dark);
    border-top: 3px solid var(--accent);
    padding: 40px 24px 24px;
    margin-top: 64px;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 32px;
    margin-bottom: 32px;
  }
  .footer-brand img {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    margin-bottom: 12px;
  }
  .footer-brand p { font-size: 14px; color: rgba(255,255,255,0.5); line-height: 1.6; }
  .footer-col h5 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .footer-col a {
    display: block;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    font-size: 14px;
    margin-bottom: 8px;
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--white); }
  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 24px;
    border-top: 1px solid rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 13px;
    color: rgba(255,255,255,0.3);
  }

  /* PAGE SECTIONS (hidden by default) */
  .page { display: none; }
